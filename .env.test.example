# Test environment template.
# Copy to .env.test and fill in real values:  cp .env.test.example .env.test

# backend service base url, test environment
VITE_SERVICE_BASE_URL=http://127.0.0.1:8080/api/v1

VITE_OTHER_SERVICE_BASE_URL={"demo":"http://localhost:9528"}

# disable realtime websocket in test mode for deterministic runs
VITE_REALTIME_ENABLED=N
VITE_LOGIN_CODE_LOGIN_ENABLED=N
VITE_LOGIN_BIND_WECHAT_ENABLED=N
