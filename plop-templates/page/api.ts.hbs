import type { CustomAxiosRequestConfig, FlatResponseData } from '@sa/axios';

function createScaffoldResponse<T>(data: T): FlatResponseData<any, T> {
  return {
    data,
    error: null,
    response: { data } as never
  };
}

function createScaffoldError(method: string): FlatResponseData<any, never> {
  const response = {
    data: {
      code: '9001',
      msg: `[scaffold] Wire {{routeName}} facade to the generated SDK before using ${method}.`
    }
  } as never;

  return {
    data: null,
    error: { response } as never,
    response
  };
}

export function fetchGet{{pascalName}}List(
  params: Api.{{pascalName}}.{{pascalName}}ListParams
): Promise<FlatResponseData<any, Api.{{pascalName}}.{{pascalName}}List>> {
  return Promise.resolve(
    createScaffoldResponse({
      current: params.current,
      size: params.size,
      total: 0,
      records: []
    })
  );
}

export function fetchCreate{{pascalName}}(
  _data: Api.{{pascalName}}.{{pascalName}}Payload,
  _config?: CustomAxiosRequestConfig
): Promise<FlatResponseData<any, never>> {
  return Promise.resolve(createScaffoldError('create'));
}

