<script setup lang="ts">
import { computed, h, ref } from 'vue';
import { NAlert, NButton, NPopconfirm } from 'naive-ui';
import { fetchDelete{{pascalName}}, fetchGet{{pascalName}}List } from '@/service/api';
import { useAppStore } from '@/store/modules/app';
import { useAuth } from '@/hooks/business/auth';
import { useCrudTable } from '@/hooks/business/crud-table';
import { defaultTransform, renderEnableStatusTag, useNaivePaginatedTable } from '@/hooks/common/table';
import { $t } from '@/locales';
import TableWrapper from '@/components/advanced/table-wrapper.vue';
import {{pascalName}}OperateDrawer from './modules/{{routeName}}-operate-drawer.vue';
import {{pascalName}}Search from './modules/{{routeName}}-search.vue';

defineOptions({
  name: '{{pascalName}}Page'
});

const appStore = useAppStore();
const { hasAuth } = useAuth();
const canManage{{pascalName}} = computed(() => hasAuth('{{routeName}}.manage'));

const searchParams = ref({
  current: 1,
  size: 10,
  status: null as Api.Common.EnableStatus | null,
  keyword: null as string | null
});

const { columns, columnChecks, data, getData, getDataByPage, loading, mobilePagination } = useNaivePaginatedTable({
  api: () =>
    fetchGet{{pascalName}}List({
      current: searchParams.value.current,
      size: searchParams.value.size,
      status: searchParams.value.status ?? undefined,
      keyword: searchParams.value.keyword ?? undefined
    }),
  transform: response => defaultTransform(response),
  onPaginationParamsChange: params => {
    searchParams.value.current = params.page ?? 1;
    searchParams.value.size = params.pageSize ?? 10;
  },
  columns: () => [
    ...(canManage{{pascalName}}.value
      ? [
          {
            type: 'selection' as const,
            align: 'center' as const,
            width: 48
          }
        ]
      : []),
    {
      key: 'index',
      title: $t('common.index'),
      align: 'center',
      width: 64,
      render: (_row, index) => (searchParams.value.current - 1) * searchParams.value.size + index + 1
    },
    {
      key: '{{codeKey}}',
      title: $t('page.{{routeName}}.{{codeKey}}'),
      align: 'center',
      minWidth: 180
    },
    {
      key: '{{nameKey}}',
      title: $t('page.{{routeName}}.{{nameKey}}'),
      align: 'center',
      minWidth: 220
    },
    {
      key: 'status',
      title: $t('common.status'),
      align: 'center',
      width: 110,
      render: row => renderEnableStatusTag(row.status)
    },
    {
      key: 'updateTime',
      title: $t('common.updatedAt'),
      align: 'center',
      width: 180
    },
    {
      key: 'operate',
      title: $t('common.operate'),
      align: 'center',
      width: canManage{{pascalName}}.value ? 220 : 96,
      fixed: 'right',
      render: row => {
        const viewButton = h(
          NButton,
          {
            type: 'default',
            ghost: true,
            size: 'small',
            onClick: () => view(row.id)
          },
          { default: () => $t('common.view') }
        );

        if (!canManage{{pascalName}}.value) {
          return h('div', { class: 'flex-center gap-8px' }, [viewButton]);
        }

        return h('div', { class: 'flex-center gap-8px' }, [
          viewButton,
          h(
            NButton,
            {
              type: 'primary',
              ghost: true,
              size: 'small',
              onClick: () => edit(row.id)
            },
            { default: () => $t('common.edit') }
          ),
          h(
            NPopconfirm,
            { onPositiveClick: () => handleDelete(row.id) },
            {
              default: () => $t('common.confirmDelete'),
              trigger: () =>
                h(
                  NButton,
                  {
                    type: 'error',
                    ghost: true,
                    size: 'small'
                  },
                  { default: () => $t('common.delete') }
                )
            }
          )
        ]);
      }
    }
  ]
});

const {
  viewMode,
  drawerVisible,
  operateType,
  editingData,
  checkedRowKeys,
  add: crudAdd,
  edit: crudEdit,
  view: crudView,
  handleDelete: crudHandleDelete,
  handleBatchDelete: crudHandleBatchDelete
} = useCrudTable({
  data,
  idKey: 'id',
  getData,
  canManage: canManage{{pascalName}},
  deleteById: fetchDelete{{pascalName}}
});

function add() {
  crudAdd();
}

function edit(id: number) {
  crudEdit(id);
}

function view(id: number) {
  crudView(id);
}

async function handleDelete(id: number) {
  await crudHandleDelete(id);
}

async function handleBatchDelete() {
  await crudHandleBatchDelete();
}

function handleSearch() {
  searchParams.value.current = 1;
  getDataByPage();
}

function handleSubmitted() {
  getDataByPage();
}
</script>

<template>
  <TableWrapper :title="$t('route.{{routeName}}')">
    <template #search>
      <{{pascalName}}Search v-model:model="searchParams" @search="handleSearch" />
    </template>
    <template #header-extra>
      <div class="flex flex-col gap-12px">
        <NAlert type="info" :bordered="false">
          <!-- eslint-disable-next-line vue/no-v-text -->
          <span v-text="$t('page.{{routeName}}.scaffoldNotice')" />
        </NAlert>
        <TableHeaderOperation
          v-model:columns="columnChecks"
          :show-add="canManage{{pascalName}}"
          :show-delete="canManage{{pascalName}}"
          :disabled-delete="!canManage{{pascalName}} || checkedRowKeys.length === 0"
          :loading="loading"
          @add="add"
          @delete="handleBatchDelete"
          @refresh="getData"
        />
      </div>
    </template>
    <NDataTable
      v-model:checked-row-keys="checkedRowKeys"
      size="small"
      class="sm:h-full"
      remote
      :columns="columns"
      :data="data"
      :loading="loading"
      :flex-height="!appStore.isMobile"
      :scroll-x="980"
      :row-key="row => row.id"
      :pagination="mobilePagination"
    />
    <template #operate>
      <{{pascalName}}OperateDrawer
        v-model:visible="drawerVisible"
        :operate-type="operateType"
        :row-data="editingData"
        :read-only="viewMode || !canManage{{pascalName}}"
        @submitted="handleSubmitted"
      />
    </template>
  </TableWrapper>
</template>
