# Live full-stack demo frontend build.
# Copy to .env.demo-live when building the Vue app against a real hosted Laravel demo backend.

VITE_BASE_URL=/
VITE_APP_RUNTIME=backend
VITE_APP_TITLE=Obsidian Admin Demo
VITE_APP_DESC=Contract-driven Vue admin paired with a hosted Laravel demo backend

VITE_ROUTER_HISTORY_MODE=hash
VITE_AUTH_ROUTE_MODE=dynamic
VITE_HTTP_PROXY=N
VITE_REALTIME_ENABLED=Y
VITE_AUTOMATICALLY_DETECT_UPDATE=N
VITE_LOGIN_CODE_LOGIN_ENABLED=N
VITE_LOGIN_BIND_WECHAT_ENABLED=N

VITE_SERVICE_BASE_URL=https://demo-api.example.com/api/v1
VITE_OTHER_SERVICE_BASE_URL=`{
  "demo": "https://demo-api.example.com/api/v1"
}`

VITE_REVERB_SCHEME=https
VITE_REVERB_HOST=demo-api.example.com
VITE_REVERB_PORT=6001
VITE_REVERB_APP_KEY=replace-demo-key
